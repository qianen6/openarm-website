yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# inspection scripts and dumps (development only)
inspect-glb.mjs
inspect-glb-full.mjs
inspect-arm.mjs
